# Inquiry & email (server-only secrets — set in .env.local or Vercel)
RESEND_API_KEY=
INQUIRY_NOTIFICATION_TO=
INQUIRY_FROM_EMAIL=

# Optional: Google Sheets / Zapier / Apps Script webhook
INQUIRY_WEBHOOK_URL=

# Public WhatsApp number for fallback contact buttons (digits only or E.164)
NEXT_PUBLIC_WHATSAPP_NUMBER=
